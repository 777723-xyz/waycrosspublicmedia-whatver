                                {
                                 "duration":"0.25",
                                 "ease":"Linear",
                                 "target":"pickleCounter",
                                 "x":"1",
                                 "y":"1"
                                },
                             "type":"ez.display.ScaleTo"
                            }],
                     "type":"ez.Sequence"
                    }],
             "name":"AddPickle"
            }, 
            {
             "actions":[
                    {
                     "properties":
                        {
                         "soundChannel":"BGM"
                        },
                     "type":"ez.sound.StopChannel"
                    }, 
                    {
                     "properties":
                        {
                         "disposeUnusedAssets":"true",
                         "duration":"0.5",
                         "scene":"EndGame",
                         "transition":"None"
                        },
                     "type":"ez.scene.ChangeScene"
                    }],
             "name":"endGame"
            }, 
            {
             "actions":[
                    {
                     "properties":
                        {
                         "isMiniGame":"false",
                         "missionLevel":"2",
                         "missionName":"3"
                        },
                     "type":"com.utils.sdk.CallDeltaMissionStartedEvent"
                    }, 
                    {
                     "properties":
                        {
                         "ignoreIfMute":"false",
                         "loop":"true",
                         "shouldBeUnique":"true",
                         "sound":"bgm\/musicloop_level2",
                         "soundChannel":"BGM",
                         "stopWhenTargetDisposed":"true",
                         "volume":"1",
                         "waitForComplete":"false"
                        },
                     "type":"ehdi.EHDIPlaySound"
                    }],
             "name":"playBGM"
            }]
