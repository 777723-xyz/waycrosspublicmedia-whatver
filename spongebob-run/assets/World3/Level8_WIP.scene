                    }],
             "name":"pointerUp"
            }, 
            {
             "actions":[
                    {
                     "properties":
                        {
                         "location":"Local",
                         "message":"pointerDown",
                         "target":"Spongebob"
                        },
                     "type":"ez.EmitMessage"
                    }],
             "name":"pointerDown"
            }, 
            {
             "actions":[
                    {
                     "properties":
                        {
                         "duration":"0.5",
                         "opaque":"false",
                         "scene":"pause",
                         "transition":"None"
                        },
                     "type":"ez.scene.PushScene"
                    }],
             "name":"pauseGame"
            }, 
            {
             "actions":[
                    {
                     "subActions":[
                            {
                             "properties":
