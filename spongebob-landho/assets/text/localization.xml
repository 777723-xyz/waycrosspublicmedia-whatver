				Optional attributes: fontName="Arial" fontScale="1" align="center" offsetX="0" offsetY="0" -->

		<style name="default" fontName="20_white_pressstart" align="center"></style>
		<style name="title" fontName="20_white_pressstart" align="center" offsetY="0"></style>

		<style name="win" fontName="20_white_pressstart" align="left" offsetY="0"></style>

		<style name="16_pink" fontName="16_pink_pressstart" align="center" offsetY="0"></style>

